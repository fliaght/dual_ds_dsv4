# Recipe: concurrent-32k  (BATCH THROUGHPUT)
# Smaller context, 4 concurrent sequences, MTP off. Maximises aggregate tok/s
# for many short requests rather than single-stream latency.
#
# Behaviour: peak aggregate ~34.9 tok/s at concurrency=4 with 128/128 shapes.
# OSL<=4k. Per-stream rate collapses under long prompts (the 32k-context KV pool
# saturates fast under load). See docs/PERFORMANCE.md section "Concurrency".

MAX_MODEL_LEN=32768            # 1/4 the context -> bigger effective batch headroom
GPU_MEM_UTIL=0.75             # weights alone need ~0.61 of UMA; 0.75 leaves a KV pool + headroom
MAX_NUM_SEQS=4                # up to 4 streams batched together
MAX_NUM_BATCHED_TOKENS=8192
BLOCK_SIZE=256
KV_DTYPE=fp8
CUDAGRAPH_MODE=NONE

# MTP off: speculative decoding hurts batch throughput (draft/verify overhead
# competes with real batched decode) and adds ITL variance.
MTP_CONF=
