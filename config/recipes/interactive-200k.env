# Recipe: interactive-200k  (PRODUCTION DEFAULT)
# Single-request, MTP-on, full 131k context. Tuned for interactive chat / agents:
# lowest per-token latency, longest input, multi-turn prefix-cache reuse.
# Sourced by scripts/run-node.sh.  MODEL comes from cluster.conf, not here.
#
# Behaviour: post-warm short-context ~23-25 tok/s, OSL<=8k, combined ISL+OSL
# up to ~124k. See docs/PERFORMANCE.md.

MAX_MODEL_LEN=131072            # full advertised context; YaRN (factor 16) auto-applies >65536
GPU_MEM_UTIL=0.80              # 0.85 left only ~7 GiB free at idle -> watchdog crashes on
                               # activation surges. 0.80 keeps ~15 GiB headroom. Costs ~6 GiB KV.
MAX_NUM_SEQS=1                 # single-stream; higher reserves per-seq overhead we never use
MAX_NUM_BATCHED_TOKENS=8192    # chunked-prefill chunk size. 32768 ate ~12 GiB workspace for no gain.
BLOCK_SIZE=256                 # model-arch requirement (vLLM page granularity)
KV_DTYPE=fp8                   # mandatory on this HW; halves KV vs bf16, no measured quality drop
CUDAGRAPH_MODE=NONE            # DeepGEMM's n_valid.item() sync is illegal during graph capture
                               # (cudaErrorStreamCaptureUnsupported). NONE is the only stable mode.

# Multi-Token Prediction (speculative decoding, num_speculative_tokens=2).
# ~1.6x single-stream speedup at ~70% draft acceptance (98% on repetitive long
# context). Requires the aux_stream sed hot-patch that run-node.sh applies.
MTP_CONF='{"method":"mtp","num_speculative_tokens":2}'
