# Recipe: long-output  (MTP OFF)
# Same engine sizing as interactive-200k but with speculative decoding disabled.
# Disabling MTP frees ~1.7 GiB of KV pool (15.4 -> 17.1 GiB) and removes the
# per-step draft state, raising the single-shot output ceiling from ~8k to ~12k.
#
# Use for long-form generation (code refactors, multi-section reports, >8k
# output) where total output length matters more than per-token latency.
# Behaviour: post-warm ~12 tok/s (vs ~24 with MTP), OSL<=12k. See docs/RECIPES.md.

MAX_MODEL_LEN=131072
GPU_MEM_UTIL=0.80
MAX_NUM_SEQS=1
MAX_NUM_BATCHED_TOKENS=8192
BLOCK_SIZE=256
KV_DTYPE=fp8
CUDAGRAPH_MODE=NONE

# MTP intentionally OFF — leave MTP_CONF empty/unset. run-node.sh skips the
# --speculative-config flag entirely when MTP_CONF is empty.
MTP_CONF=
